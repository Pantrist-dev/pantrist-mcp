# Pantrist REST API base URL (no trailing slash).
PANTRIST_BASE_URL=https://api.pantrist.app

# --- stdio transport (local, single-user PoC) ------------------------------
# A Bearer token accepted by the API. Best: an OAuth access_token, or a
# Firebase ID token copied from the app. NOTE: a Pantrist API key
# (<uuid>_<secret>) works for list/shopping/pantry/week-plan tools but NOT the
# recipe tools (see docs/AUTHENTICATION.md). Only used by the stdio transport.
PANTRIST_TOKEN=

# Default list UUID used when a tool call omits `listId`. Optional — call the
# `list_lists` tool to discover ids. STDIO ONLY: ignored by the HTTP transport,
# where every user must pass listId explicitly (no shared default).
PANTRIST_LIST_ID=

# --- HTTP (Streamable HTTP) transport (remote / multi-user) ----------------
PORT=8787
# Public URL this MCP server is reachable at; advertised in the OAuth
# protected-resource metadata. Set to the exact base clients connect to.
MCP_PUBLIC_URL=http://localhost:8787

# Optional DNS-rebinding protection. When either is set the transport rejects
# requests whose Host/Origin isn't allow-listed. Leave unset behind a trusted
# TLS-terminating ingress that already pins Host. Comma-separated.
# MCP_ALLOWED_HOSTS=mcp.pantrist.app
# MCP_ALLOWED_ORIGINS=https://claude.ai

# JSON body size cap for POST /mcp. Default is 4mb; raise if you expect
# large tool payloads (full pantry dumps, etc.).
# MCP_BODY_LIMIT=4mb

# --- API-side: required for the remote OAuth flow ---------------------------
# These are set on the Pantrist API (not the MCP server) but are listed here
# because the MCP OAuth handshake breaks without them.
#
# OAUTH_AUTHORIZE_URL must point at a browser-facing consent page that runs
# the user's Firebase login and then calls POST /access-token/authorize.
# The API's own /access-token/authorize is a Firebase-guarded JSON endpoint —
# it cannot be the target of a browser navigation, so without this override
# every MCP-client login flow 401s before the user sees a UI.
# OAUTH_AUTHORIZE_URL=https://pantrist.app/oauth/authorize
